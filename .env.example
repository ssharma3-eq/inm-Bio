# Environment Variables

# Email Configuration (for contact form)
NEXT_PUBLIC_EMAIL_ADDRESS=info@inm-bioneno.co.in
NEXT_PUBLIC_PHONE=+91 90000 00000
NEXT_PUBLIC_ADDRESS=Bangalore, India

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000

# Email Service (optional - for sending emails)
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-password

# Analytics (optional)
NEXT_PUBLIC_GA_ID=your-google-analytics-id

# Commerce (if setting up e-commerce)
NEXT_PUBLIC_STRIPE_KEY=your-stripe-key
STRIPE_SECRET_KEY=your-stripe-secret
